# ---------------------------------------------------------------------------
# model.env — single source of truth for the served model
#
# Change these values to swap models. Then run ./deploy.sh.
# All scripts and k8s manifests derive their model settings from here.
# ---------------------------------------------------------------------------

# Model identity (must match the directory name under $REPO_ROOT)
MODEL_NAME="Qwen2.5-7B-Instruct"

# HuggingFace repo (used by download_models.sh / online asset mode)
MODEL_HF_REPO="Qwen/Qwen2.5-7B-Instruct"

# vLLM serving settings — tune per model size
VLLM_MAX_MODEL_LEN=32768
VLLM_GPU_MEMORY_UTILIZATION=0.95

# k8s resource limits for the vLLM decode pod
# Rule of thumb: REQUEST  = model weights in fp16 (7B ≈ 14GB → 12Gi is safe)
#                LIMIT    = REQUEST + headroom for KV cache / activations
VLLM_MEMORY_REQUEST="12Gi"
VLLM_MEMORY_LIMIT="24Gi"
